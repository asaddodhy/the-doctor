# The Doctor — WhatsApp Listener

# Comma-separated list of allowed phone numbers (international format, no +)
# Example: DOCTOR_WHATSAPP_ALLOWED=491512345678,491517654321
# Leave empty to accept all incoming voice notes
DOCTOR_WHATSAPP_ALLOWED=

# Path to bridge script (overrides default)
# DOCTOR_BRIDGE_SCRIPT=

# Path to Python interpreter for bridge script (overrides default)
# DOCTOR_BRIDGE_PYTHON=

# The Doctor — Test Environment Configuration
# This file is used when DOCTOR_ENV=test
# Copy of production .env with test numbers

# Same Telegram Bot Token (shared between prod and test)
DOCTOR_BOT_TOKEN=8733555468:AAEQFcLirA7laLksGprAcXreNDhAMeknqyk

# Test Telegram user ID (Asad's other account)
DOCTOR_ALLOWED_USERS=8907737065

# Test WhatsApp number (Asad's other number, international format, no +)
DOCTOR_WHATSAPP_ALLOWED=447919360289

# Groq Whisper API for STT (primary transcription method)
# Get your API key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Path to bridge script (default: ~/Documents/Development/perplexity-stack/scripts/transcribe.py)
# DOCTOR_BRIDGE_SCRIPT=

# Path to Python interpreter for bridge script (default: perplexity-stack's venv python3)
# DOCTOR_BRIDGE_PYTHON=

# Path to Perplexity cookies (default: ~/.config/perplexity/cookies.json)
# PERPLEXITY_COOKIES_PATH=

# Perplexity API server (should already be running on port 8001 from perplexity-stack)
PERPLEXITY_API_URL=http://127.0.0.1:8001

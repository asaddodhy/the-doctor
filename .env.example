# The Doctor — Environment Configuration

# Telegram Bot Token (get from @BotFather on Telegram)
DOCTOR_BOT_TOKEN=

# Comma-separated list of allowed Telegram user IDs (optional)
# If empty, anyone with the bot link can send messages
DOCTOR_ALLOWED_USERS=

# Comma-separated list of allowed WhatsApp numbers (international, no +)
# Example: DOCTOR_WHATSAPP_ALLOWED=491512345678
DOCTOR_WHATSAPP_ALLOWED=

# Path to bridge script (default: ~/Documents/Development/perplexity-stack/scripts/transcribe.py)
DOCTOR_BRIDGE_SCRIPT=

# Path to Python interpreter for bridge script (default: perplexity-stack's venv python3)
DOCTOR_BRIDGE_PYTHON=

# Path to Perplexity cookies (default: ~/.config/perplexity/cookies.json)
# PERPLEXITY_COOKIES_PATH=
